generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}
model Company {
  id           String           @id @default(cuid())
  ticker       String           @unique
  name         String
  sector       String?
  exchange     String?
  marketCap    Float?
  score        Float?
  category     String?
  updatedAt    DateTime         @updatedAt
  metrics      Metric?
  valuation    Valuation?
  guidances    GuidanceHistory[]
  guidanceMeta GuidanceMeta?
}
model Metric {
  id               String  @id @default(cuid())
  companyId        String  @unique
  roic             Float?
  revenueCAGR3Y    Float?
  netDebtEbitda    Float?
  interestCoverage Float?
  fcfYield         Float?
  guidanceScore    Float?
  marginOfSafety   Float?
  company          Company @relation(fields: [companyId], references: [id])
}
model Valuation {
  id             String  @id @default(cuid())
  companyId      String  @unique
  pe             Float?
  peg            Float?
  evEbit         Float?
  pFcf           Float?
  intrinsicValue Float?
  company        Company @relation(fields: [companyId], references: [id])
}
model GuidanceHistory {
  id            String   @id @default(cuid())
  ticker        String
  year          Int
  metric        String
  guidanceValue String?
  guidanceLow   String?
  guidanceHigh  String?
  actualValue   String?
  beat          Boolean?
  sourceUrl     String?
  extractedAt   DateTime @default(now())
  company       Company  @relation(fields: [ticker], references: [ticker])
  @@unique([ticker, year, metric])
  @@index([ticker])
}
model GuidanceMeta {
  ticker         String   @id
  lastReportDate DateTime
  lastSearchedAt DateTime
  dataQuality    String
  company        Company  @relation(fields: [ticker], references: [ticker])
}
model Watchlist {
  id        String   @id @default(cuid())
  name      String
  tickers   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvestmentIdea {
  id        String   @id @default(cuid())
  ticker    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Company info
  company  String
  country  String
  sector   String

  // Investment thesis
  thesis    String
  catalysts String[]
  valuation String?
  risks     String[]

  // Valuation metrics snapshot
  per            Float?
  evEbit         Float?
  fcfYield       Float?
  revGrowth3Y    Float?
  debtToEbitda   Float?
  marginOfSafety Float?
  valuationClass String

  // Thesis challenge
  implicitAssumptions String[]
  weakPoints          String[]
  hiddenRisks         String[]
  marketingArgs       String[]
  whyBadIdea          String

  // Scoring (/100)
  discountScore        Float
  catalystScore        Float
  businessQualityScore Float
  thesisSolidityScore  Float
  accessibilityScore   Float
  sourceQualityScore   Float
  totalScore           Float

  // Conviction
  convictionLevel  String
  convictionReason String

  @@index([ticker])
  @@index([totalScore])
  @@index([convictionLevel])
}
