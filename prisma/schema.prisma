generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id           String            @id @default(cuid())
  ticker       String            @unique
  name         String
  sector       String?
  exchange     String?
  marketCap    Float?
  currentPrice Float?
  score        Float?
  category     String?
  updatedAt    DateTime          @updatedAt
  metrics      Metric?
  valuation    Valuation?
  guidances    GuidanceHistory[]
  guidanceMeta GuidanceMeta?
}

model Metric {
  id               String  @id @default(cuid())
  companyId        String  @unique
  roic             Float?
  revenueCAGR3Y    Float?
  netDebtEbitda    Float?
  interestCoverage Float?
  fcfYield         Float?
  guidanceScore    Float?
  marginOfSafety   Float?
  // ── Advanced metrics ──────────────────────────────
  insiderOwnership      Float?
  fcfConversionRatio    Float?
  buybackQualityScore   Int?
  roiic                 Float?
  reinvestmentRate      Float?
  intrinsicCompoundingRate Float?
  accrualsRatio         Float?
  piotroskiFScore       Int?
  grossMarginStability  Float?
  capexIntensity        Float?
  moatQuantScore        Int?
  founderBadge          Boolean?
  ceoTenureYears        Int?
  distanceFromATH       Float?
  performance6M         Float?
  rsiMonthly            Float?
  revenueGrowthYoY      Float?
  // ── Piotroski F-Score individuel ─────────────────
  pioF1RoaPositive            Boolean?
  pioF2CfoPositive            Boolean?
  pioF3RoaImproving           Boolean?
  pioF4CfoVsNetIncome         Boolean?
  pioF5LeverageDecreasing     Boolean?
  pioF6LiquidityImproving     Boolean?
  pioF7NoDilution             Boolean?
  pioF8GrossMarginImproving   Boolean?
  pioF9AssetTurnoverImproving Boolean?
  // ── Nouveau scoring (sous-scores) ────────────────
  scoreCompounding      Float?
  scoreFinancial        Float?
  scoreEarnings         Float?
  scoreValuation        Float?
  // ── Métriques valuation avancées ─────────────────
  marginOfSafetyBear    Float?
  ownerEarningsYield    Float?
  ownerEarnings         Float?
  incrementalMargin     Float?
  // ── Moat Analysis ────────────────────────────────
  moatPricingPower      Float?
  moatSwitchingCosts    Float?
  moatCostAdvantage     Float?
  moatNetworkEffects    Float?
  moatIntangibleAssets  Float?
  moatGlobalScore       Int?
  moatPricingEvidence   String?
  moatSwitchingEvidence String?
  moatCostEvidence      String?
  moatNetworkEvidence   String?
  moatIntangibleEvidence String?
  // ── Score Breakdown ───────────────────────────────
  scoreBreakdownJson    String?
  // ── Dette & Trésorerie ────────────────────────────
  cashAndEquivalents    Float?
  totalDebtValue        Float?
  netDebt               Float?
  netDebtToFCF          Float?
  currentRatio          Float?
  quickRatio            Float?
  goodwillToAssets      Float?
  returnOnTangibleAssets Float?
  equityRatio           Float?
  dso                   Float?
  dpo                   Float?
  cashConversionCycle   Float?
  company          Company @relation(fields: [companyId], references: [id])
}

model Valuation {
  id             String  @id @default(cuid())
  companyId      String  @unique
  pe             Float?
  peg            Float?
  evEbit         Float?
  pFcf           Float?
  intrinsicValue Float?
  company        Company @relation(fields: [companyId], references: [id])
}

model GuidanceHistory {
  id            String   @id @default(cuid())
  ticker        String
  year          Int
  metric        String
  guidanceValue String?
  guidanceLow   String?
  guidanceHigh  String?
  actualValue   String?
  beat          Boolean?
  sourceUrl     String?
  extractedAt   DateTime @default(now())
  company       Company  @relation(fields: [ticker], references: [ticker])
  @@unique([ticker, year, metric])
  @@index([ticker])
}

model GuidanceMeta {
  ticker         String   @id
  lastReportDate DateTime
  lastSearchedAt DateTime
  dataQuality    String
  company        Company  @relation(fields: [ticker], references: [ticker])
}

model Watchlist {
  id        String   @id @default(cuid())
  name      String
  tickers   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
